<?xml version="1.0" encoding="utf-8" ?>
<configuration>
    <startup> 
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
    </startup>
	<system.serviceModel>
		<bindings>
   <basicHttpBinding>
	<binding name="BasicHttpBinding_IUserService" />
	<binding name="BasicHttpBinding_IWordService" />
	<binding name="BasicHttpBinding_IAuthService" />
	<binding name="BasicHttpBinding_IMatchService" />
   </basicHttpBinding>
  </bindings>
		<client>
   <endpoint address="http://localhost:64696/Services/UserService.svc"
	binding="basicHttpBinding" bindingConfiguration="BasicHttpBinding_IUserService"
	contract="HangmanGameService.IUserService" name="BasicHttpBinding_IUserService" />
   <endpoint address="http://localhost:64696/Services/WordService.svc"
	binding="basicHttpBinding" bindingConfiguration="BasicHttpBinding_IWordService"
	contract="HangmanGameService.IWordService" name="BasicHttpBinding_IWordService" />
   <endpoint address="http://localhost:64696/Services/AuthService.svc"
	binding="basicHttpBinding" bindingConfiguration="BasicHttpBinding_IAuthService"
	contract="HangmanGameService.IAuthService" name="BasicHttpBinding_IAuthService" />
   <endpoint address="http://localhost:64696/Services/MatchService.svc"
	binding="basicHttpBinding" bindingConfiguration="BasicHttpBinding_IMatchService"
	contract="HangmanGameService.IMatchService" name="BasicHttpBinding_IMatchService" />
  </client>
	</system.serviceModel>
</configuration>