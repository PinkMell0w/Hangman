<Page x:Class="HangmanGame.Client.Views.CreateMatch.CreateMatchPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:HangmanGame.Client.Views.CreateMatch"
      xmlns:props="clr-namespace:HangmanGame.Client.Properties"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="900"
      Title="{x:Static props:Resources.Title_createMatch}">

    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="/Resources/Images/paperBgB.jpg" TileMode="None" Stretch="Fill"/>
        </Grid.Background>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Margin="10,10,10,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            
            <TextBlock Text="Selecciona una categoría" FontSize="26" FontFamily="Ink Free" FontWeight="Bold" />
            <StackPanel Grid.Row="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,10,10,0" HorizontalAlignment="Center">
                <Button Content="Animales" Padding="10" Margin="0,0,10,0" FontSize="24" Width="140" />
                <Button Content="Frutas" Padding="10" Margin="0,0,10,0" FontSize="24" Width="140" />
                <Button Content="Colores" Padding="10" Margin="0,0,10,0" FontSize="24" Width="140" />
                <Button Content="Objetos" Padding="10" Margin="0,0,10,0" FontSize="24" Width="140" />
                <Button Content="Países" Padding="10" FontSize="24" Width="140" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="10,10,10,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            
            <TextBlock Text="Y una palabra" FontSize="20" FontFamily="Ink Free" FontWeight="Bold" Margin="0,10,0,10" />
            <Grid Grid.Row="1" x:Name="GdCategories">
                <ItemsControl ItemsSource="{Binding Words}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Height="150" ScrollViewer.VerticalScrollBarVisibility="Auto" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding Name}"
                                Margin="5"
                                Padding="10" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Vertical" HorizontalAlignment="Left" Margin="10,0,10,10">
            <TextBlock Text="O escribe una propia:" FontSize="20" FontFamily="Ink Free" FontWeight="Bold" Margin="0,10,0,10" />
            <TextBox Width="250" Height="30" FontSize="14" />
        </StackPanel>

        <Grid Grid.Row="3">
            <Button Name="BtnGoBack" Content="Volver" HorizontalAlignment="Left" Margin="10,0,0,10" Padding="10" Command="{Binding NavigateToLobbyCommand}" />
            <Button Name="BtnCreateMatch" Content="Crear partida" HorizontalAlignment="Right" Margin="0,0,10,10" Padding="10" Command="{Binding CreateWaitingRoomCommand}" />
        </Grid>
    </Grid>
</Page>
