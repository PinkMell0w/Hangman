<Page x:Class="HangmanGame.Client.Views.LobbyPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:HangmanGame.Client.Views"
      xmlns:props="clr-namespace:HangmanGame.Client.Properties"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="900"
      Title="{x:Static props:Resources.Title_lobby}">

    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="/Resources/Images/paperBgA.jpg" TileMode="None" Stretch="Fill"/>
        </Grid.Background>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Orientation="Vertical" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10, 10, 10, 0">
                <Button Name="BtnCreateMatch" Margin="0,0,0,10" Padding="5" Height="30" Content="{x:Static props:Resources.Button_createMatch}" Command="{Binding CreateMatchCommand}" />
                <Button Name="BtnJoinMatch" Margin="0,0,0,10" Padding="5" Height="30" Content="{x:Static props:Resources.Button_joinMatch}" Command="{Binding JoinMatchCommand}" />
                <Button Name="BtnProfile" Margin="0,0,0,10" Padding="5" Height="30" Content="{x:Static props:Resources.Button_profile}" Command="{Binding ProfileCommand}" />
                <Button Name="BtnSettings" Margin="0,0,0,10" Padding="5" Height="30" Content="{x:Static props:Resources.Global_settings}" Command="{Binding SettingsCommand}" />
                <Button Name="BtnLogout" Padding="5" Height="30" Content="{x:Static props:Resources.Button_logOut}" Command="{Binding LogOutCommand}" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Grid.Row="1" HorizontalAlignment="Left" Margin="10,0,0,10">
                <Image Source="/Resources/Images/PlayerPfp.png" HorizontalAlignment="Left" Margin="0,0,10,0" Width="50" Height="50"/>
                <TextBlock Text="{Binding Username}" FontSize="16" FontFamily="Ink Free" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="10, 10, 10, 10"/>
            </StackPanel>
        </Grid>

        <Image Grid.Column="1" Source="/Resources/Images/Lobby.png" Stretch="None" HorizontalAlignment="Center" Margin="0,0,80,0" />

    </Grid>
</Page>
