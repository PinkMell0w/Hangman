<Page x:Class="HangmanGame.Client.Views.MatchesList.MatchesListPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:HangmanGame.Client.Views.MatchesList"
      xmlns:props="clr-namespace:HangmanGame.Client.Properties"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="900"
      Title="{x:Static props:Resources.Title_matchesList}">

    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="/Resources/Images/paperBg.jpg" TileMode="None" Stretch="Fill"/>
        </Grid.Background>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="{x:Static props:Resources.Text_availableMatches}" FontSize="24" FontFamily="Ink Free" FontWeight="Bold" Margin="20,20,0,10"/>
            <Button Name="BtnGoBack" Content="{x:Static props:Resources.Button_goBack}" Margin="20,0,0,0" HorizontalAlignment="Left" Padding="8" Command="{Binding GoBackCommand}"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel VerticalAlignment="Bottom">
                <Button Name="BtnSettings" Padding="5" Margin="20,0,0,10" HorizontalAlignment="Left" Command="{Binding GoToSettingsCommand}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="/Resources/Images/Settings.png" Height="20"/>
                        <TextBlock Text="{x:Static props:Resources.Global_settings}" FontSize="12" VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </StackPanel>
                </Button>

                <Button Name="BtnProfile" Padding="8" Margin="20,0,20,20" HorizontalAlignment="Left" Command="{Binding ViewProfileCommand}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="/Resources/Images/PlayerPfp.png" Height="40"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding Username}" FontSize="14" VerticalAlignment="Center" Margin="8,0,0,5"/>
                            <TextBlock Text="{x:Static props:Resources.Button_viewProfile}" FontSize="10" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Button>
            </StackPanel>

            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalAlignment="Center" Grid.Column="1">
                <ItemsControl ItemsSource="{Binding Matches}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Command="{Binding DataContext.JoinMatchCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    CommandParameter="{Binding MatchId}"
                                    Padding="8"
                                    Margin="20,0,20,10">

                                <StackPanel Orientation="Horizontal">
                                    <Image Source="/Resources/Images/PlayerPfp.png" Height="60"/>
                                    <StackPanel>
                                        <TextBlock Text="{Binding HostName}" FontSize="14" Margin="8,0,0,0"/>
                                        <TextBlock FontSize="10" Margin="8,0,0,0">
                                            <Run Text="{x:Static props:Resources.Text_playersInMatch}"/>
                                            <Run Text="{Binding CurrentPlayers}"/>
                                            <Run Text="/"/>
                                            <Run Text="{Binding MaxPlayers}"/>
                                        </TextBlock>
                                        <TextBlock FontSize="8" Margin="8,0,0,0">
                                            <Run Text="{x:Static props:Resources.Text_created}" />
                                            <Run Text=" " />
                                            <Run Text="{Binding CreatedAt}" />
                                        </TextBlock>
                                    </StackPanel>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <Button Grid.Column="2" Name="BtnRefresh" Content="{x:Static props:Resources.Button_refresh}" Padding="5" Margin="100,0,20,20" HorizontalAlignment="Right" VerticalAlignment="Bottom" Command="{Binding RefreshListCommand}"/>
        </Grid>
    </Grid>
</Page>
