<Page x:Class="HangmanGame.Client.Views.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:HangmanGame.Client.Views"
      xmlns:props="clr-namespace:HangmanGame.Client.Properties"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="900"
      Title="{x:Static props:Resources.Title_profile}">

    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="/Resources/Images/paperBgB.jpg" TileMode="None" Stretch="Fill"/>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel x:Name="UserInfoPanel" Visibility="Visible" Margin="20,20,0,0">
                <TextBlock Text="{x:Static props:Resources.Global_username}" FontSize="22" FontFamily="Ink Free" FontWeight="Bold" HorizontalAlignment="Left" Margin="0,0,0,10"/>
                <TextBlock Text="{Binding Username}" FontSize="32" Margin="0,0,0,10" Width="200" HorizontalAlignment="Left"/>
                
                <TextBlock Text="Nombre completo" FontSize="20" FontFamily="Ink Free" FontWeight="Bold" HorizontalAlignment="Left" Margin="0,0,0,10"/>
                <TextBlock Text="{Binding FullName}" FontSize="26" Margin="0,0,0,10" HorizontalAlignment="Left"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="40,0,0,20">
                    <StackPanel Margin="0,0,20,0" Background="PaleVioletRed">
                        <TextBlock Text="Partidas jugadas" FontSize="16" FontFamily="Ink Free" FontWeight="Bold" Padding="8"/>
                        <TextBlock Text="{Binding GamesPlayed}" FontSize="20" Padding="8" Width="100" HorizontalAlignment="Left"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,20,0" Background="CornflowerBlue">
                        <TextBlock Text="Victorias totales" FontSize="16" FontFamily="Ink Free" FontWeight="Bold" Padding="8"/>
                        <TextBlock Text="{Binding GamesWon}" FontSize="20" Padding="8" Width="100" HorizontalAlignment="Left"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel HorizontalAlignment="Left" Margin="40,0,0,10" Background="AliceBlue">
                    <TextBlock Text="Porcentaje de victorias" FontSize="20" FontFamily="Ink Free" FontWeight="Bold" Padding="5"/>
                    <TextBlock Text="{Binding WinRate}" FontSize="32" Padding="8" Width="100" HorizontalAlignment="Left"/>
                </StackPanel>
                
                <TextBlock Text="Tema" FontSize="16" FontFamily="Ink Free" FontWeight="Bold" HorizontalAlignment="Left" Margin="0,0,0,10"/>
                <TextBlock Text="{Binding Theme}" FontSize="20" Margin="0,0,0,10" Width="200" HorizontalAlignment="Left"/>
                
                <TextBlock Text="Acerca de" FontSize="16" FontFamily="Ink Free" FontWeight="Bold" HorizontalAlignment="Left" Margin="0,0,0,10"/>
                <TextBlock Text="{Binding Bio}" FontSize="20" Margin="0,0,0,10" TextWrapping="Wrap" Width="300" HorizontalAlignment="Left"/>
            </StackPanel>

            <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Top">
                <TextBlock Text="Foto de perfil" FontSize="22" FontFamily="Ink Free" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,80,0,20"/>
                <Image x:Name="profilePic" Source="/Resources/Images/PlayerPfp.png" Margin="0,0,0,20" Width="160"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" VerticalAlignment="Bottom">
            <Button Name="BtnGoBack" Content="Volver" Margin="20,0,0,10" HorizontalAlignment="Left" Padding="8" Command="{Binding NavigateToLobbyCommand}"/>
            <Button Name="BtnModifyProfile" Content="Modificar perfil" Margin="20,0,140,10" HorizontalAlignment="Right" Padding="8" />
            <Button Name="BtnDeleteProfile" Content="Eliminar perfil" Margin="0,0,20,10" HorizontalAlignment="Right" Padding="8" />
        </Grid>
    </Grid>
</Page>
