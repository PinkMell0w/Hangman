<Page x:Class="HangmanGame.Client.Views.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:HangmanGame.Client.Views"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ProfilePage">

    <Grid Background="Gray">
        <StackPanel Orientation="Vertical" Margin="10, 10, 10, 10">
            <Label x:Name="lbUsername" Content="PLACEHOLDER_USERNAME"/>
            <Label x:Name="lbWins" Content="PLACEHOLDER_WINS"/>
            <Label x:Name="lbLoses" Content="PLACEHOLDER_LOSES"/>
            <Label x:Name="lbWinrate" Content="PLACEHOLDER_WINRATE"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Margin="50, 300, 0, 10">
            <Button Click="Button_Click" Content="volver" Height="30"/>
        </StackPanel>
    </Grid>
</Page>
