<Page x:Class="HangmanGame.Client.Views.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:HangmanGame.Client.Views"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ProfilePage">

    <Grid Background="Gray">
        <StackPanel Orientation="Vertical" Margin="10, 10, 10, 10">
            <TextBlock Text="Username:" FontWeight="Bold"/>
            <TextBlock Text="{Binding Username}" />
            <TextBlock Text="Full name:" FontWeight="Bold" Margin="0,6,0,0"/>
            <TextBlock Text="{Binding FullName}" />
            <TextBlock Text="Games played:" FontWeight="Bold" Margin="0,6,0,0"/>
            <TextBlock Text="{Binding GamesPlayed}" />
            <TextBlock Text="Games won:" FontWeight="Bold" Margin="0,6,0,0"/>
            <TextBlock Text="{Binding GamesWon}" />
            <TextBlock Text="Win rate:" FontWeight="Bold" Margin="0,6,0,0"/>
            <TextBlock Text="{Binding WinRate}" />
            <TextBlock Text="Theme:" FontWeight="Bold" Margin="0,6,0,0"/>
            <TextBlock Text="{Binding Theme}" />
            <TextBlock Text="Bio:" FontWeight="Bold" Margin="0,6,0,0"/>
            <TextBlock Text="{Binding Bio}" TextWrapping="Wrap" Width="300"/>
        </StackPanel>

        <Image x:Name="profilePic" Width="128" Height="128" HorizontalAlignment="Right" Margin="0,10,10,0"/>

        <StackPanel Orientation="Horizontal" Margin="50, 300, 0, 10">
            <Button Click="Button_Click" Content="volver" Height="30"/>
        </StackPanel>
    </Grid>
</Page>
