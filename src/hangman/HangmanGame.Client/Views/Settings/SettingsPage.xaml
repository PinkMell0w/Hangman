<Page x:Class="HangmanGame.Client.Views.Settings.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:HangmanGame.Client.Views.Settings"
      xmlns:props="clr-namespace:HangmanGame.Client.Properties"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="900"
      Title="{x:Static props:Resources.Title_settings}">

    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="/Resources/Images/paperBg.jpg" TileMode="None" Stretch="Fill"/>
        </Grid.Background>
        
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock Text="{x:Static props:Resources.Global_settings}" FontSize="32" FontFamily="Ink Free" FontWeight="Bold" HorizontalAlignment="Center" Margin="20,20,0,10"/>

        <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,20,0,0">
            <TextBlock Text="{x:Static props:Resources.Text_language}" FontSize="20" FontFamily="Ink Free" FontWeight="Bold" Margin="20,0,0,5"/>
            <ComboBox SelectedValue="{Binding SelectedLanguage}" SelectedValuePath="Tag" Margin="20,0,0,20" Width="250" FontSize="16" VerticalContentAlignment="Center">
                <ComboBoxItem Tag="system" Content="{x:Static props:Resources.Text_useSystemDefault}" IsSelected="True"/>
                <ComboBoxItem Tag="es-MX" Content="Español"/>
                <ComboBoxItem Tag="en-US" Content="English"/>
                <ComboBoxItem Tag="de-DE" Content="Deutsch"/>
            </ComboBox>
        </StackPanel>

        <Grid Grid.Row="2">
            <Button Name="BtnGoBack" Content="{x:Static props:Resources.Button_goBack}" Margin="20,0,0,10" HorizontalAlignment="Left" Padding="8" Command="{Binding GoBackCommand}" />
            <Button Name="BtnSaveSettings" Content="{x:Static props:Resources.Button_saveSettings}" Margin="0,0,20,10" HorizontalAlignment="Right" Padding="8" Command="{Binding SaveSettingsCommand}" />
        </Grid>
    </Grid>
</Page>
