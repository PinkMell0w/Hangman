<Page x:Class="HangmanGame.Client.Views.SignInPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:HangmanGame.Client.Views"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="SignInPage">

    <Grid Background="Gray">
        <StackPanel Orientation="Vertical" Margin="10, 10, 10, 10" HorizontalAlignment="Center">
            <TextBox x:Name="tbUsername" Text="{Binding Credential, UpdateSourceTrigger=PropertyChanged}" />
            <PasswordBox x:Name="pbPassword" PasswordChanged="pbPassword_PasswordChanged" Margin="0, 10, 0, 10"/>
            <Button Content="Sign in" Command="{Binding SignInCommand}"/>
        </StackPanel>
    </Grid>
</Page>
