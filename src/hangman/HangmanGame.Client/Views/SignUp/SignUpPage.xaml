<Page x:Class="HangmanGame.Client.Views.SignUp.SignUpPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:HangmanGame.Client.Views.SignUp"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="SignUpPage">

    <Grid Background="DimGray">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Vertical" HorizontalAlignment="Center" Margin="10, 10, 10, 10">
                <Label Content="FName" FontSize="16"/>
                <TextBox/>
                <Label Content="dob" FontSize="16"/>
                <DatePicker />
                <Label Content="pNumber" FontSize="16"/>
                <TextBox/>
                <Label Content="Username" FontSize="16"/>
                <TextBox/>
                <Label Content="Password" FontSize="16"/>
                <TextBox/>
                <Label Content="confirm password" FontSize="16"/>
                <TextBox/>
            </StackPanel>

            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="20, 20, 20, 20">
                <Button x:Name="btnLogin" Content="placeholder_log" Click="btnLoginPage_Click" Margin="10, 5, 10, 5"/>
                <Button x:Name="btnRegister" Content="placeholder_Reg" Click="btnRegister_click" Margin="10, 5, 10, 5"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
